generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String     @unique
  emailVerified DateTime?
  password      String?
  role          Role       @default(WORKER)
  phone         String?
  image         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  accounts      Account[]
  sessions      Session[]
  zakázky       Zakázka[]  @relation("PracovnikZakazky")
  faktury       Faktura[]
}

model Zákazník {
  id        String    @id @default(cuid())
  jmeno     String
  email     String?
  telefon   String?
  adresa    String?
  poznamka  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  objekty   Objekt[]
  zakázky   Zakázka[]
}

model Objekt {
  id         String    @id @default(cuid())
  adresa     String
  typ        String?
  poznamka   String?
  zakaznikId String
  zákazník   Zákazník  @relation(fields: [zakaznikId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  zakázky    Zakázka[]
}

model Zakázka {
  id           String       @id @default(cuid())
  cislo        Int          @default(autoincrement())
  nazev        String
  popis        String?
  stav         StavZakazky  @default(NOVA)
  typ          TypPrace     @default(KOMINSTVI)
  adresa       String
  cena         Float?
  datumZahajeni DateTime?
  datumDokonceni DateTime?
  postup       Int          @default(0)
  zakaznikId   String?
  pracovnikId  String?
  objektId     String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  zákazník     Zákazník?    @relation(fields: [zakaznikId], references: [id])
  pracovnik    User?        @relation("PracovnikZakazky", fields: [pracovnikId], references: [id])
  objekt       Objekt?      @relation(fields: [objektId], references: [id])
  fotky        Fotka[]
  faktury      Faktura[]
  dokumenty    Dokument[]
}

model Fotka {
  id        String   @id @default(cuid())
  url       String
  nazev     String?
  zakazkaId String
  zakázka   Zakázka  @relation(fields: [zakazkaId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Faktura {
  id          String        @id @default(cuid())
  cislo       String        @unique
  castka      Float
  dph         Float         @default(21)
  stav        StavFaktury   @default(NOVA)
  splatnost   DateTime?
  zakazkaId   String?
  userId      String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  zakázka     Zakázka?      @relation(fields: [zakazkaId], references: [id])
  vystavil    User?         @relation(fields: [userId], references: [id])
}

model Dokument {
  id        String       @id @default(cuid())
  nazev     String
  typ       TypDokumentu @default(OSTATNI)
  url       String?
  obsah     String?      @db.Text
  zakazkaId String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  zakázka   Zakázka?     @relation(fields: [zakazkaId], references: [id])
}

model SkladItem {
  id          String   @id @default(cuid())
  nazev       String
  jednotka    String   @default("ks")
  mnozstvi    Float    @default(0)
  minMnozstvi Float    @default(0)
  cena        Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  MANAGER
  WORKER
}

enum StavZakazky {
  NOVA
  CEKA
  PROBIHA
  HOTOVO
  FAKTURACE
  ZAPLACENO
}

enum TypPrace {
  KOMINSTVI
  STAVBA
  REVIZE
  MONTAZ
  OPRAVA
}

enum StavFaktury {
  NOVA
  ODESLANA
  ZAPLACENA
  PO_SPLATNOSTI
  STORNO
}

enum TypDokumentu {
  REVIZNI_ZPRAVA
  SMLOUVA
  PROTOKOL
  BOZP
  FAKTURA
  OSTATNI
}
